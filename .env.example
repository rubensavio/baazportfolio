# Google Calendar API - Workspace (domain-wide delegation)
GOOGLE_CALENDAR_ID=chit@baaz.live
GOOGLE_CALENDAR_IMPERSONATE=chit@baaz.live
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Workspace Admin → Security → API controls → Domain-wide delegation
# Client ID + scope: https://www.googleapis.com/auth/calendar
#
# Personal Gmail fallback (no impersonate - share calendar with service account instead):
# GOOGLE_CALENDAR_ID=you@gmail.com
# GOOGLE_CALENDAR_IMPERSONATE=

# ── Calendly (time-slot source) ──
# When CALENDLY_TOKEN is set, /book-call availability is sourced from Calendly's
# real availability instead of the hardcoded Google free/busy grid. Booking still
# writes to Google Calendar (which Calendly treats as a conflict if linked).
# Token: Calendly → Integrations → API & Webhooks → Personal Access Token.
CALENDLY_TOKEN=...
# CALENDLY_EVENT_SLUG=30min
